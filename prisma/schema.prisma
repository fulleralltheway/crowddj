generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  rooms         Room[]
}

model Room {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  hostId          String
  host            User     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  playlistId      String
  playlistName    String
  isActive        Boolean  @default(true)
  votesPerUser    Int      @default(5)
  voteResetMinutes Int     @default(30)
  requireApproval  Boolean  @default(false)
  votingPaused     Boolean  @default(false)
  maxSongsPerGuest Int      @default(0) // 0 = unlimited
  explicitFilter   Boolean  @default(false)
  autoShuffle      Boolean  @default(true)
  queueDisplaySize Int      @default(50)
  allowDuplicates  Boolean  @default(false) // allow songs to be replayed after being played
  maxSongDurationSec Int    @default(0) // 0 = full length, otherwise max seconds per song before auto-transition
  blockedArtists   String   @default("") // comma-separated blocked artist names
  blockedSongs     String   @default("") // comma-separated blocked spotify URIs
  scheduledStart   DateTime? // optional scheduled start time
  brandColor       String   @default("") // custom accent color hex, empty = default green
  brandName        String   @default("") // custom display name for branding
  totalSongsPlayed Int      @default(0) // event stats
  totalVotesCast   Int      @default(0) // event stats
  peakGuestCount   Int      @default(0) // event stats
  lastSyncAdvance  DateTime @default(now()) // debounce sync advances
  lastPreQueuedId  String?  // ID of the song we last pre-queued, to avoid duplicate queue adds
  createdAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt
  songs           RoomSong[]
  guests          Guest[]
  songRequests    SongRequest[]
}

model RoomSong {
  id        String @id @default(cuid())
  roomId    String
  room      Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  spotifyUri    String
  trackName     String
  artistName    String
  albumArt      String?
  durationMs    Int
  sortOrder     Int
  upvotes       Int    @default(0)
  downvotes     Int    @default(0)
  isPlaying     Boolean @default(false)
  isPlayed      Boolean @default(false)
  isLocked      Boolean @default(false)
  isRequested   Boolean @default(false) // true if guest-requested (always shown in display)
  isPinned      Boolean @default(false) // set list planner: pinned to position
  pinnedPosition Int?   // target position in set list
  previewUrl    String? // Spotify 30s preview MP3 URL
  tempo         Float?  // BPM from Spotify audio features
  energy        Float?  // 0.0-1.0 energy level
  danceability  Float?  // 0.0-1.0 danceability
  addedBy       String? // fingerprint of who requested it, null if from original playlist
  addedByName   String?
  createdAt     DateTime @default(now())
  votes         Vote[]
}

model Guest {
  id             String   @id @default(cuid())
  roomId         String
  room           Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  fingerprint    String
  name           String   @default("")
  votesUsed      Int      @default(0)
  lastVoteReset  DateTime @default(now())
  totalUpvotes   Int      @default(0)
  totalDownvotes Int      @default(0)
  createdAt      DateTime @default(now())
  votes          Vote[]

  @@unique([roomId, fingerprint])
}

model Vote {
  id        String   @id @default(cuid())
  guestId   String
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  songId    String
  song      RoomSong @relation(fields: [songId], references: [id], onDelete: Cascade)
  value     Int      // 1 for upvote, -1 for downvote
  createdAt DateTime @default(now())
}

model SongRequest {
  id         String   @id @default(cuid())
  roomId     String
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  spotifyUri String
  trackName  String
  artistName String
  albumArt   String?
  durationMs Int
  requestedBy     String // fingerprint
  requestedByName String @default("")
  status      String  @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
}
